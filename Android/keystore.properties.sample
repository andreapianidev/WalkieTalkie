# Copy this file to `keystore.properties` and fill in your own values.
# `keystore.properties` and the .keystore/.jks files are gitignored: NEVER commit them.
#
# Generate a keystore with:
#   keytool -genkeypair -v -keystore release.keystore -alias talky \
#     -keyalg RSA -keysize 2048 -validity 10000
storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=talky
keyPassword=CHANGE_ME
